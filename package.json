{
  "name": "split-seconds-mobile-qa",
  "version": "0.53.0",
  "private": true,
  "scripts": {
    "serve": "vite --host 0.0.0.0",
    "build": "vite build && node tools/copy_static_assets.js",
    "qa:screens": "playwright test tests/mobile-screens.spec.js",
    "qa:runtime-ai": "playwright test tests/runtime-ai.spec.js",
    "qa:install": "playwright install chromium",
    "mobile:build": "npm run build && npx cap sync android",
    "mobile:add:android": "npm run build && npx cap add android",
    "mobile:open:android": "npx cap open android",
    "mobile:run:android": "npm run build && npx cap run android",
    "sim:balance": "node tools/simulate_balance.js --games 5000 --seed 1337",
    "sim:old-ai": "node tools/simulate_balance_old_ai.js --games 3000 --seed 69001",
    "sim:smart-ai-only": "node tools/simulate_balance_smart_ai_only.js --games 3000 --seed 69002",
    "sim:smart-vs-old": "node tools/simulate_balance_smart_vs_old.js --games 4000 --seed 69003",
    "sim:skill-curve": "node tools/compare_skill_curve.js --games 1200 --seed 71000",
    "sim:skill-matrix": "node tools/compare_skill_matrix.js --games 250 --seed 72000",
    "sim:auto-balance-fast": "node tools/auto_balance_fast.js --iterations 10 --games 5000 --matrixGames 1500 --seed 75000",
    "sim:validate-truth": "node tools/validate_sim_true_to_game.js tools/simulate_balance_smart_ai_only.js",
    "sim:sync-roster": "node tools/sync_sim_from_game_roster.js",
    "sim:validate-generated-roster": "node tools/validate_generated_roster_truth.js",
    "sim:validate-rules": "node tools/validate_rules_parity.js",
    "test:v79-target-layout": "node tools/validate_v79_target_layout.js"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@playwright/test": "^1.48.0",
    "vite": "^5.0.0"
  }
}
